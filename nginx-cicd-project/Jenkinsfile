pipeline {
    agent any

    stages {
		stage('Debug Files') {
    		steps {
        		sh 'ls -la'
    		}
		}
		
        stage('Build Docker Image') {
            steps {
                echo 'Creating Docker image...'
                sh 'docker build -t nginx-website .'
            }
            
        }

        stage('Stop Old Container') {
            steps {
		echo 'Stoping Old Container'
                sh 'docker stop nginx-container || true'
                sh 'docker rm nginx-container || true'
            }
        }

        stage('Run New Container') {
            steps {
		echo 'Running Container'
                sh 'docker run -d -p 80:80 --name nginx-container nginx-website'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Deploing to kubernetes....'
            }
        }
    

    }
    
}

