pipeline {
    agent any

    stages {
		stage('Debug Files') {
    		steps {
        		sh 'ls -la'
    		}
		}
		
        stage('Build Docker Image') {
            steps {
                echo 'Creating Docker image...'
                sh 'docker build -t nginx-website ./nginx-cicd-project'
            }
            
        }

        stage('Stop Old Container') {
            steps {
		echo 'Stoping Old Container'
                sh 'docker stop nginx-container || true'
                sh 'docker rm nginx-container || true'
            }
        }

        stage('Load Image Into Kind') {
            steps {
		echo 'Loading image into kind'
                sh 'kind load docker-image nginx-website'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
        echo 'Deploing to kubernetes....'
                sh 'kubectl apply -f ./nginx-cicd-project/deployment.yaml'  
                sh 'kubectl apply -f ./nginx-cicd-project/service.yaml'     
            }
        }
    

    }
    
}

