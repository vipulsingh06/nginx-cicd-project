pipeline {
    agent any

    environment {
        KUBECONFIG = '/var/lib/jenkins/.kube/config'
    }

    stages {
        stage('Debug Files') {
            steps {
                        sh 'ls -la'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Creating Docker image...'
                sh 'docker build --pull=false -t nginx-website ./nginx-cicd-project'
            }

        }


        stage('Load Image Into Kind') {
            steps {
                echo 'Loading image into kind'
                sh 'kind load docker-image nginx-website'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
            sh '''
            export KUBECONFIG=/var/lib/jenkins/.kube/config

            echo "Waiting for Kubernetes API..."

            Ready=false

            for i in {1..10}; do
            if /usr/bin/kubectl cluster-info; then
                echo "Kubernetes API is ready!"
                Ready=true
                break
            fi
            echo "Waiting ..."
            sleep 5
            done

            if [ "$Ready" = false ]; then
                echo "Kubernetes API is not ready after waiting. Exiting."
                exit 1
            fi
            /usr/bin/kubectl get nodes

            /usr/bin/kubectl apply --validate=false -f ./nginx-cicd-project/deployment.yaml
            /usr/bin/kubectl apply --validate=false -f ./nginx-cicd-project/service.yaml

            /usr/bin/kubectl rollout restart deployment nginx-website
            /usr/bin/kubectl rollout status deployment nginx-website
            '''
            }
        }

        stage('Expose Service') {
            steps {
            echo 'Exposing nginx service...'
            sh '''
            pkill -f "kubectl port-forward" || true
            nohup kubectl port-forward --address 0.0.0.0 service/nginx-service 80:80 > /dev/null 2>&1 &
            '''
            }
        }

    }

}Jenkinsfile

