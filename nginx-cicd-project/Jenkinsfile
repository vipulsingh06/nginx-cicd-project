pipeline {
    agent any

    stages {
		stage('Debug Files') {
    		steps {
        		sh 'ls -la'
    		}
		}
		
        stage('Build Docker Image') {
            steps {
                echo 'Creating Docker image...'
                sh 'docker build -t nginx-website ./nginx-cicd-project'
            }
            
        }


        stage('Load Image Into Kind') {
            steps {
		echo 'Loading image into kind'
                sh 'kind load docker-image nginx-website'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
        echo 'Deploying to kubernetes....'
        sh '''
        kubectl apply -f ./nginx-cicd-project/deployment.yaml
        kubectl apply -f ./nginx-cicd-project/service.yaml
        kubectl rollout restart deployment nginx-website
        '''   
            }
        }
    

    }
    
}

